# Gilbert installation data (per-instance config, database, logs, plugin cache)
.gilbert/

# Nexia library auto-writes per-house config caches to the working
# directory (named ``<brand>_config_<house_name>.conf``) — sometimes
# bypassing the plugin's configured ``state_file`` path. Treat any
# such file at the repo root as accidental + sensitive (contains
# auth tokens) and never commit it.
/nexia_config_*.conf
/asair_config_*.conf

# Plugin directories
#
# std-plugins/ — the first-party gilbert-plugins repository. Tracked as
#   a git submodule (.gitmodules + gitlink). Do NOT gitignore it — the
#   submodule pointer lives in gilbert's tree.
# local-plugins/ — plugins the user writes locally. Never tracked.
# installed-plugins/ — plugins fetched at runtime from external sources
#   (GitHub URLs, etc.). Managed by the plugin loader.
#
# We keep the empty scaffolds for local-plugins/ and installed-plugins/
# around (via README.md) so gilbert.yaml's ``plugins.directories`` works
# out of the box on a fresh clone without the user having to mkdir.
local-plugins/*
!local-plugins/README.md
installed-plugins/*
!installed-plugins/README.md

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/

# Virtual environment
.venv/

# Testing
.pytest_cache/
.coverage
htmlcov/

# IDE
.idea/
.vscode/
*.swp
*.swo

# mypy
.mypy_cache/

# ruff
.ruff_cache/

# Frontend build
node_modules/
frontend/tsconfig.tsbuildinfo
frontend/node_modules/
frontend/dist/
package-lock.json
# Built SPA is fully generated from the frontend source every time
# ``gilbert.sh start`` runs (it ``rm -rf``s this directory and copies
# a fresh ``frontend/dist`` into it). Tracking anything here just
# creates commit churn on every build with zero runtime value, so
# the whole tree is ignored. If you need to run Gilbert without
# ``gilbert.sh`` (e.g. a stripped-down container), build the frontend
# separately and copy ``frontend/dist`` into place.
src/gilbert/web/spa/
